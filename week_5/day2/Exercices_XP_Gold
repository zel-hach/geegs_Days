CREATE TABLE purchases (
    id SERIAL PRIMARY KEY,
    customer_id INT,
    item_id INT,
    quantity_purchased INT,
    FOREIGN KEY (customer_id) REFERENCES customers(id),
    FOREIGN KEY (item_id) REFERENCES items(id)
);
	
)


